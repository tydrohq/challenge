# Tydro Challenge — environment.
# Copy to `.env` (`cp .env.example .env`) before running anything.
# ForkBase fails loudly naming any var that is unset.
#
# These are working, non-secret defaults (a public RPC + a pinned block). The hiring team
# may override INK_RPC_URL with a private/archive endpoint if the public one is rate-limited.

# Ink RPC endpoint (archive state required for the pinned block).
# Verified working (archive back past block 40M): rpc-gel / rpc-qnd / ink.drpc.org
INK_RPC_URL=https://rpc-gel.inkonchain.com

# Pinned fork block (recent, confirmed retrievable on all three public RPCs).
FORK_BLOCK=48050000

# The asset whose oracle the candidate repoints (Task 1). Default: WETH market.
ORACLE_MIGRATION_TARGET=0x4200000000000000000000000000000000000006

# Candidate EOA: anvil account 0 (default mnemonic). Public test key — NOT a secret.
# Used only against the local anvil fork; never against a live network.
CANDIDATE=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
